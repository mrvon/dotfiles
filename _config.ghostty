theme = Arthur

bold-color = bright

font-family = Monaco Nerd Font
font-family = Noto Sans Mono CJK SC
font-size = 14
font-codepoint-map = U+00D7=Monaco Nerd Font

cursor-style = block
cursor-style-blink = true

keybind = ctrl+,=unbind
keybind = ctrl+enter=text:\x0d
keybind = f11=toggle_fullscreen

window-padding-x = 0
window-padding-y = 0

mouse-scroll-multiplier = 0.5
